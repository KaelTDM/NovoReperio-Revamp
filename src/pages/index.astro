    .stack-support-card::before {
      content: "";
      position: absolute;
      left: -22px;
      top: 50%;
      width: 22px;
      height: 1px;
      background: linear-gradient(90deg, rgba(21,159,230,.36), rgba(21,159,230,0));
      transform: translateY(-50%);
