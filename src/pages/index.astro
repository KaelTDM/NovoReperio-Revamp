    .stack-orb::before,
    .stack-orb::after {
      content: "";
      position: absolute;
      inset: 16px;
      border: 1px solid rgba(21,159,230,.24);
      border-radius: 50%;
    }
    .stack-orb::after {
      inset: 9px 22px;
      border-radius: 50%;
    }
    .stack-orb-label {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      color: var(--nr-red-dark);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .12em;
      text-transform: uppercase;
    }
    .stack-browser {
      position: absolute;
      right: 16px;
      bottom: 14px;
      width: 116px;
      height: 86px;
      border-radius: 16px;
      border: 1px solid rgba(21,159,230,.12);
      background: linear-gradient(180deg, rgba(255,255,255,.94), rgba(246,249,252,.88));
      box-shadow: 0 14px 24px rgba(16,17,20,.08);
      overflow: hidden;
      transition: opacity .5s ease, transform .72s cubic-bezier(.22, 1, .36, 1);
      will-change: opacity, transform;
    }
    .stack-browser::before {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      top: 0;
      height: 18px;
      background: linear-gradient(180deg, rgba(21,159,230,.16), rgba(21,159,230,.04));
      border-bottom: 1px solid rgba(21,159,230,.1);
    }
    .stack-browser::after {
      content: "";
      position: absolute;
      left: 14px;
      right: 14px;
      top: 30px;
      height: 42px;
      border-radius: 10px;
      background:
        linear-gradient(180deg, rgba(21,159,230,.18), rgba(21,159,230,.04)),
        linear-gradient(90deg, rgba(16,17,20,.05) 0 34%, transparent 34% 100%);
