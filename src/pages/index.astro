    <section id="pricing" class="pricing"><div class="container"><div class="section-title"><h2>Every scope starts with the space, the audience, and the decision you need to move.</h2><p>Every project is scoped around what the space needs to communicate, the audience it needs to persuade, and how the final output will be used.</p></div><div class="scope-board"><div class="scope-overview"><span class="eyebrow">How Novo scopes work</span><h3>One process. Different outputs. Built around the use case.</h3><p>The recommended stack is shaped around the space, the audience, and the decision the experience needs to support after launch.</p><div class="scope-tags"><span>Hospitality</span><span>Venues</span><span>Property</span><span>Facilities</span></div><div class="scope-cta"><a class="btn btn-primary" href="#demo">Request Quote</a><a class="btn btn-secondary" href="#stories">See Relevant Work</a></div><p class="scope-note">The final recommendation depends on space size, decision complexity, delivery format, and how quickly the asset needs to be live.</p></div><div class="scope-process"><article class="scope-step"><div class="scope-step-top"><span class="scope-step-number">01</span><div class="scope-step-visual assess" aria-hidden="true"><span class="node"></span><span class="beam"></span></div></div><h3>Assess the space</h3><p>Start with the type of environment, what must be shown clearly, and which stakeholders need confidence before visiting.</p><ul><li>Single venue or multi-site rollout</li><li>Hospitality, property, retail, or facilities use</li><li>Operational review vs public-facing marketing</li></ul></article><article class="scope-step"><div class="scope-step-top"><span class="scope-step-number">02</span><div class="scope-step-visual match" aria-hidden="true"><span class="ring"></span></div></div><h3>Match the output</h3><p>Choose the right combination of capture, support media, and packaging based on how the asset will actually be used.</p><ul><li>Matterport or lighter 360 tour</li><li>Drone, stills, CGI, or launch website support</li><li>Deck, web, QR, or sales handoff format</li></ul></article><article class="scope-step"><div class="scope-step-top"><span class="scope-step-number">03</span><div class="scope-step-visual plan" aria-hidden="true"><span class="node"></span><span class="beam"></span></div></div><h3>Plan the rollout</h3><p>Confirm the level of polish, timeline, and handoff needed so the output lands well with the intended audience.</p><ul><li>Fast capture and publish</li><li>Polished campaign-ready delivery</li><li>Ongoing support for repeat locations</li></ul></article></div></div></div></section>

    <section id="demo" class="final-cta"><div class="container cta-panel"><div><h2>Ready to make your physical space easier to understand remotely?</h2><p>Novo Reperio can help you capture, package, and launch a digital experience that makes venue buyers, property prospects, operators, and stakeholders feel more certain, faster.</p></div><div class="cta-buttons"><a class="btn btn-primary" href="#footer">Request Quote</a><a class="btn btn-secondary" href="#stories">See Our Work</a></div></div></section>
  </main>

  <script define:vars={{ industrySectors, stackServices, industryPreviewItems }}>
    const hero = document.querySelector(".hero");
    if (hero && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      hero.addEventListener("pointermove", (event) => {
        const rect = hero.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width) * 100;
        const y = ((event.clientY - rect.top) / rect.height) * 100;
        hero.style.setProperty("--cursor-x", `${x}%`);
        hero.style.setProperty("--cursor-y", `${y}%`);
        hero.classList.add("is-glow-active");
      });

      hero.addEventListener("pointerleave", () => {
        hero.classList.remove("is-glow-active");
      });
    }

    const counters = Array.from(document.querySelectorAll("[data-countup]"));
    if (counters.length && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      const animateCount = (element) => {
        if (element.dataset.done === "true") return;
        element.dataset.done = "true";

        const target = Number(element.dataset.target || "0");
        const suffix = element.dataset.suffix || "";
        const duration = 1400;
        const startTime = performance.now();

        const step = (now) => {
          const progress = Math.min((now - startTime) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const value = Math.round(target * eased);
          element.textContent = `${value}${suffix}`;
          if (progress < 1) requestAnimationFrame(step);
        };

        requestAnimationFrame(step);
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const delay = Number(entry.target.dataset.delay || "0");
            entry.target.classList.add("is-visible");
            window.setTimeout(() => animateCount(entry.target), delay);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.45 });

      counters.forEach((counter, index) => {
        counter.dataset.delay = String(index * 110);
        counter.style.transitionDelay = `${index * 70}ms`;
        observer.observe(counter);
      });
    } else {
      counters.forEach((element) => {
        const suffix = element.dataset.suffix || "";
        element.classList.add("is-visible");
        element.textContent = `${element.dataset.target || "0"}${suffix}`;
      });
    }

    const sectorData = industrySectors;
    const stackData = stackServices;
    const industryArcData = industryPreviewItems;
    const sectorTabs = Array.from(document.querySelectorAll("[data-sector-tab]"));
    const sectorMedia = document.getElementById("industry-media");
    const sectorVisual = document.querySelector("[data-industry-visual]");
    const sectorChip = document.querySelector("[data-industry-chip]");
    const sectorProjectName = document.querySelector("[data-industry-project-name]");
    const sectorProjectLink = document.querySelector("[data-industry-project-link]");
    const sectorPanel = document.getElementById("industry-panel");
    const sectorCopyBody = document.querySelector("[data-industry-copy-body]");
    const sectorTitle = document.querySelector("[data-industry-title]");
    const sectorDescription = document.querySelector("[data-industry-description]");
    const sectorBullets = document.querySelector("[data-industry-bullets]");
    const sectorReviewLink = document.querySelector("[data-industry-review-link]");

    if (
        sectorTabs.length &&
        sectorMedia &&
        sectorVisual &&
        sectorChip &&
        sectorProjectName &&
        sectorProjectLink &&
        sectorPanel &&
        sectorCopyBody &&
        sectorTitle &&
        sectorDescription &&
        sectorBullets &&
        sectorReviewLink
    ) {
      let activeSectorKey = sectorData[0]?.key || "";
      let swapTimer;

      const commitSector = (nextSector) => {
        sectorVisual.style.backgroundImage = `url("${nextSector.image}")`;
        sectorMedia.setAttribute("aria-labelledby", `industry-tab-${nextSector.key}`);
        sectorChip.textContent = nextSector.label;
        sectorProjectName.textContent = nextSector.projectName;
        sectorProjectLink.href = nextSector.projectUrl;
        sectorProjectLink.textContent = nextSector.projectCta;
        sectorTitle.textContent = nextSector.title;
        sectorDescription.textContent = nextSector.description;
        sectorBullets.innerHTML = nextSector.bullets.map((bullet) => `<li>${bullet}</li>`).join("");
        sectorReviewLink.href = nextSector.reviewUrl;
        sectorReviewLink.textContent = nextSector.reviewLabel;
      };

      const renderSector = (key) => {
        if (!key || key === activeSectorKey || sectorMedia.dataset.switching === "true") return;
        const nextSector = sectorData.find((sector) => sector.key === key);
        if (!nextSector) return;

        sectorTabs.forEach((tab) => {
          const isActive = tab.dataset.sectorKey === key;
          tab.classList.toggle("active", isActive);
          tab.setAttribute("aria-selected", isActive ? "true" : "false");
          tab.tabIndex = isActive ? 0 : -1;
        });

        sectorMedia.dataset.switching = "true";
        sectorMedia.classList.add("is-switching");
        sectorPanel.classList.add("is-switching");
        window.clearTimeout(swapTimer);

        swapTimer = window.setTimeout(() => {
          commitSector(nextSector);
          activeSectorKey = key;
          window.setTimeout(() => {
            sectorMedia.classList.remove("is-switching");
            sectorPanel.classList.remove("is-switching");
            sectorMedia.dataset.switching = "false";
          }, 60);
        }, 300);
      };

      sectorTabs.forEach((tab, index) => {
        tab.tabIndex = index === 0 ? 0 : -1;
        tab.addEventListener("click", () => renderSector(tab.dataset.sectorKey));
        tab.addEventListener("keydown", (event) => {
          const currentIndex = sectorTabs.indexOf(tab);
          if (event.key === "ArrowDown" || event.key === "ArrowRight") {
            event.preventDefault();
            const nextIndex = (currentIndex + 1) % sectorTabs.length;
            sectorTabs[nextIndex].focus();
            renderSector(sectorTabs[nextIndex].dataset.sectorKey);
          }
          if (event.key === "ArrowUp" || event.key === "ArrowLeft") {
            event.preventDefault();
            const nextIndex = (currentIndex - 1 + sectorTabs.length) % sectorTabs.length;
            sectorTabs[nextIndex].focus();
            renderSector(sectorTabs[nextIndex].dataset.sectorKey);
          }
          if (event.key === "Home") {
            event.preventDefault();
            sectorTabs[0].focus();
            renderSector(sectorTabs[0].dataset.sectorKey);
          }
          if (event.key === "End") {
            event.preventDefault();
            sectorTabs[sectorTabs.length - 1].focus();
            renderSector(sectorTabs[sectorTabs.length - 1].dataset.sectorKey);
          }
        });
      });
    }

    const stackBoard = document.querySelector("[data-stack-board]");
    const stackCore = document.querySelector("[data-stack-core]");
    const stackCoreVisual = document.querySelector("[data-stack-core-visual]");
    const stackKicker = document.querySelector("[data-stack-kicker]");
    const stackMini = document.querySelector("[data-stack-mini]");
    const stackTitle = document.querySelector("[data-stack-title]");
    const stackDescription = document.querySelector("[data-stack-description]");
    const stackFlow = document.querySelector("[data-stack-flow]");
    const stackMetrics = document.querySelector("[data-stack-metrics]");
    const stackSupportCards = Array.from(document.querySelectorAll("[data-stack-support-card]"));

    if (
      stackBoard &&
      stackCore &&
      stackCoreVisual &&
      stackKicker &&
      stackMini &&
      stackTitle &&
      stackDescription &&
      stackFlow &&
      stackMetrics &&
      stackSupportCards.length &&
      stackData.length === 4
    ) {
      let activeStackIndex = 0;
      let stackSwapTimer;
      let stackAutoTimer;
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const getOrderedServices = (startIndex) =>
        stackData.map((_, offset) => stackData[(startIndex + offset) % stackData.length]);

      const renderCoreVisual = (visualType) => {
        if (visualType === "matterport") {
          return `<img class="stack-device" src="/images/matterport-pro3.png" alt="" loading="lazy" />`;
        }
        if (visualType === "360") {
          return `<div class="stack-orb"><span class="stack-orb-label">360</span></div>`;
        }
        if (visualType === "drone") {
          return `<div class="stack-core-drone"><img src="/images/drone.png" alt="" loading="lazy" /></div>`;
        }
        return `<div class="stack-browser"><div class="stack-browser-dots"><span></span><span></span><span></span></div></div>`;
      };

      const renderSupportVisual = (visualType) => {
        if (visualType === "matterport") {
          return `<div class="stack-support-visual" aria-hidden="true"><img src="/images/matterport-pro3.png" alt="" loading="lazy" /></div>`;
        }
        if (visualType === "360") {
          return `<div class="stack-orb" aria-hidden="true"><span class="stack-orb-label">360</span></div>`;
        }
        if (visualType === "drone") {
          return `<div class="stack-support-visual" aria-hidden="true"><img src="/images/drone.png" alt="" loading="lazy" /></div>`;
        }
        return `<div class="stack-browser" aria-hidden="true"><div class="stack-browser-dots"><span></span><span></span><span></span></div></div>`;
      };

      const commitStack = (nextIndex) => {
        const ordered = getOrderedServices(nextIndex);
        const main = ordered[0];
        const supports = ordered.slice(1);

        stackCoreVisual.dataset.visualType = main.visualType;
        stackCoreVisual.innerHTML = renderCoreVisual(main.visualType);
        stackKicker.textContent = main.eyebrow;
        stackMini.textContent = main.mini;
        stackTitle.textContent = main.title;
        stackDescription.textContent = main.description;
        stackFlow.innerHTML = main.flow
          .map((item, index) => `${index > 0 ? `<span class="stack-arrow">-&gt;</span>` : ""}<span class="stack-pill">${item}</span>`)
          .join("");
        stackMetrics.innerHTML = main.metrics
          .map((metric) => `<div class="stack-metric"><strong>${metric.label}</strong><span>${metric.value}</span></div>`)
          .join("");

        stackSupportCards.forEach((card, index) => {
          const service = supports[index];
          card.dataset.visualType = service.visualType;
          card.dataset.stackKey = service.key;
          card.setAttribute("aria-label", `Highlight ${service.supportTitle}`);
          card.innerHTML = `
            <div>
              <small>${service.supportEyebrow}</small>
              <strong>${service.supportTitle}</strong>
            </div>
            <p>${service.supportDescription}</p>
            ${renderSupportVisual(service.visualType)}
          `;
        });
      };

      const activateStack = (nextIndex) => {
        if (nextIndex === activeStackIndex || stackBoard.dataset.switching === "true") return;
        if (prefersReducedMotion) {
          commitStack(nextIndex);
          activeStackIndex = nextIndex;
          return;
        }

        stackBoard.dataset.switching = "true";
        stackBoard.classList.add("is-rotating");
        window.clearTimeout(stackSwapTimer);
        stackSwapTimer = window.setTimeout(() => {
          commitStack(nextIndex);
          activeStackIndex = nextIndex;
          window.setTimeout(() => {
            stackBoard.classList.remove("is-rotating");
            stackBoard.dataset.switching = "false";
          }, 90);
        }, 360);
      };

      const rotateStack = () => {
        if (stackBoard.dataset.switching === "true") return;
        const nextIndex = (activeStackIndex + 1) % stackData.length;
        activateStack(nextIndex);
      };

      const startStackAuto = () => {
        if (prefersReducedMotion) return;
        window.clearInterval(stackAutoTimer);
        stackAutoTimer = window.setInterval(rotateStack, 5600);
      };

      stackBoard.addEventListener("mouseenter", () => {
        if (prefersReducedMotion) return;
        window.clearInterval(stackAutoTimer);
      });

      stackBoard.addEventListener("mouseleave", () => {
        startStackAuto();
      });

      stackSupportCards.forEach((card) => {
        const activateFromCard = () => {
          const nextIndex = stackData.findIndex((service) => service.key === card.dataset.stackKey);
          if (nextIndex === -1) return;
          activateStack(nextIndex);
          startStackAuto();
        };

        card.addEventListener("click", activateFromCard);
        card.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            activateFromCard();
          }
        });
      });

      startStackAuto();
    }

    const jumpLinks = Array.from(document.querySelectorAll(".jump-nav a"));
    const jumpSections = jumpLinks
      .map((link) => document.querySelector(link.getAttribute("href")))
      .filter(Boolean);

    if (jumpLinks.length && jumpSections.length) {
      const setActiveJumpLink = (id) => {
        jumpLinks.forEach((link) => {
          const isActive = link.getAttribute("href") === `#${id}`;
          link.classList.toggle("is-active", isActive);
          link.setAttribute("aria-current", isActive ? "true" : "false");
        });
      };

      const jumpObserver = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

          if (visible[0]?.target?.id) {
            setActiveJumpLink(visible[0].target.id);
          }
        },
        {
          rootMargin: "-24% 0px -58% 0px",
          threshold: [0.2, 0.35, 0.5, 0.7],
        }
      );

      jumpSections.forEach((section) => jumpObserver.observe(section));
      setActiveJumpLink(jumpSections[0].id);
    }

    const industryArcShell = document.querySelector("[data-industry-arc]");
    const industryArcCards = Array.from(document.querySelectorAll("[data-industry-arc-card]"));

    if (industryArcShell && industryArcCards.length) {
      let activeArcIndex = 0;
      let arcTimer;
      const arcReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const shortestArcDelta = (index, activeIndex, total) => {
        let delta = index - activeIndex;
        if (delta > total / 2) delta -= total;
        if (delta < -total / 2) delta += total;
        return delta;
      };

      const applyArcState = (nextIndex) => {
        activeArcIndex = nextIndex;
        industryArcCards.forEach((card, index) => {
          const delta = shortestArcDelta(index, nextIndex, industryArcCards.length);
          const abs = Math.abs(delta);
          const hidden = abs > 2;
          const x = delta * 236;
          const y = abs === 0 ? -14 : -Math.pow(abs, 1.34) * 34;
          const scale = abs === 0 ? 1 : abs === 1 ? 0.84 : 0.68;
          const rotate = abs === 0 ? 0 : delta * -8;
          const opacity = abs === 0 ? 1 : abs === 1 ? 0.64 : 0.22;

          card.classList.toggle("is-active", abs === 0);
          card.classList.toggle("is-hidden", hidden);
          card.style.opacity = hidden ? "0" : String(opacity);
          card.style.zIndex = String(20 - abs);
          card.style.transform = `translate3d(calc(-50% + ${x}px), calc(-50% + ${y}px), 0) scale(${scale}) rotate(${rotate}deg)`;
          card.style.filter = hidden ? "blur(6px)" : abs === 0 ? "none" : abs === 1 ? "saturate(.84)" : "saturate(.72)";
          card.setAttribute("aria-hidden", hidden ? "true" : "false");
        });
      };

      const startArcAuto = () => {
        if (arcReducedMotion) return;
        window.clearInterval(arcTimer);
        arcTimer = window.setInterval(() => {
          applyArcState((activeArcIndex + 1) % industryArcCards.length);
        }, 4200);
      };

      industryArcShell.addEventListener("mouseenter", () => {
        if (arcReducedMotion) return;
        window.clearInterval(arcTimer);
      });

      industryArcShell.addEventListener("mouseleave", () => {
        startArcAuto();
      });

      industryArcCards.forEach((card) => {
        const activate = () => {
          const nextIndex = Number(card.dataset.index || "0");
          applyArcState(nextIndex);
          startArcAuto();
        };

        card.addEventListener("click", activate);
        card.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            activate();
          }
        });
      });

      applyArcState(0);
      startArcAuto();
    }
  </script>

