      overflow: hidden;
    }
    .industry-arc-shell::before {
      content: "";
      position: absolute;
      left: 50%;
      bottom: 80px;
      width: min(84%, 900px);
      height: 194px;
      border: 1px solid rgba(21,159,230,.10);
      border-top-left-radius: 999px;
      border-top-right-radius: 999px;
      border-bottom: 0;
      transform: translateX(-50%);
