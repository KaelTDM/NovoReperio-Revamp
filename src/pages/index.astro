    .scope-board {
      display: grid;
      grid-template-columns: minmax(0, .84fr) minmax(0, 1.16fr);
      gap: 26px;
      align-items: stretch;
      padding: 26px;
      border: 1px solid var(--line);
      border-radius: 30px;
      background: white;
      box-shadow: var(--shadow-soft);
    }
    .scope-overview {
      display: flex;
      flex-direction: column;
      gap: 20px;
      padding: 28px;
      border-radius: 24px;
      color: white;
      background:
        radial-gradient(circle at 16% 18%, rgba(21,159,230,.24), transparent 26%),
        linear-gradient(145deg, #0a1520, #0f1016 72%);
    }
    .scope-overview h3 {
      font-size: clamp(30px, 3.6vw, 48px);
      line-height: .98;
      letter-spacing: -.06em;
    }
    .scope-overview p {
      max-width: 420px;
      color: rgba(255,255,255,.76);
      font-size: 16px;
      line-height: 1.7;
    }
    .scope-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .scope-tags span {
      display: inline-flex;
      align-items: center;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.12);
      color: rgba(255,255,255,.88);
      background: rgba(255,255,255,.06);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .08em;
      text-transform: uppercase;
    }
    .scope-process {
      position: relative;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .scope-process::before {
      content: "";
      position: absolute;
      left: 11%;
      right: 11%;
      top: 94px;
      height: 1px;
      background: linear-gradient(90deg, rgba(243,113,33,.14), rgba(21,159,230,.24), rgba(243,113,33,.14));
      z-index: 0;
      pointer-events: none;
    }
    .scope-step {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 14px;
      padding: 24px;
      border: 1px solid var(--line);
      border-radius: 22px;
      background: linear-gradient(180deg, #fff, #fbfbfd);
      box-shadow: 0 10px 24px rgba(16,17,20,.04);
    }
    .scope-step::after {
      content: "→";
      position: absolute;
      top: 76px;
      right: -15px;
      display: grid;
      place-items: center;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      color: #f37121;
      background: #fff;
      border: 1px solid rgba(243,113,33,.18);
      box-shadow: 0 8px 18px rgba(16,17,20,.06);
      font-size: 14px;
      font-weight: 900;
    }
    .scope-step:last-child::after { display: none; }
    .scope-step-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
    }
    .scope-step-number {
      display: inline-grid;
      place-items: center;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      color: white;
      background: #f37121;
      font-size: 14px;
      font-weight: 900;
      letter-spacing: .02em;
    }
    .scope-step-visual {
      position: relative;
      flex: 0 0 auto;
      width: 92px;
      height: 72px;
      border-radius: 16px;
      border: 1px solid rgba(243,113,33,.12);
      background: linear-gradient(180deg, rgba(243,113,33,.06), rgba(21,159,230,.04));
      overflow: hidden;
    }
    .scope-step-visual .node,
    .scope-step-visual .beam,
    .scope-step-visual .ring {
      position: absolute;
      display: block;
    }
    .scope-step-visual.assess .node {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #f37121;
      box-shadow: 22px 12px 0 rgba(243,113,33,.72), 44px 0 0 rgba(243,113,33,.54), 44px 28px 0 rgba(243,113,33,.82), 16px 36px 0 rgba(243,113,33,.5);
      left: 16px;
      top: 16px;
    }
    .scope-step-visual.assess .beam {
      left: 18px;
      right: 18px;
      top: 24px;
      height: 1px;
      background: rgba(243,113,33,.32);
      box-shadow: 0 12px 0 rgba(21,159,230,.18);
    }
    .scope-step-visual.match .ring {
      inset: 14px 20px;
      border: 1px solid rgba(21,159,230,.28);
      border-radius: 999px;
    }
    .scope-step-visual.match .ring::before,
    .scope-step-visual.match .ring::after {
      content: "";
      position: absolute;
      inset: 8px;
      border: 1px solid rgba(243,113,33,.24);
      border-radius: 999px;
    }
    .scope-step-visual.match .ring::after {
      inset: 16px 10px;
      border-color: rgba(21,159,230,.24);
    }
    .scope-step-visual.plan .beam {
      left: 16px;
      right: 16px;
      bottom: 18px;
      height: 10px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(243,113,33,.24), rgba(21,159,230,.22));
      box-shadow: 0 -14px 0 rgba(243,113,33,.12), 0 -28px 0 rgba(21,159,230,.08);
    }
    .scope-step-visual.plan .node {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: #159fe6;
      right: 18px;
      top: 16px;
      box-shadow: -22px 10px 0 rgba(243,113,33,.8), -44px 18px 0 rgba(21,159,230,.42);
    }
    .scope-step h3 {
      font-size: 24px;
      line-height: 1.02;
      letter-spacing: -.05em;
    }
    .scope-step p {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.7;
    }
    .scope-step ul {
      display: grid;
      gap: 10px;
      margin-top: auto;
      padding: 0;
    }
    .scope-step li {
      list-style: none;
      color: #353941;
      font-size: 14px;
      line-height: 1.55;
      font-weight: 700;
    }
    .scope-step li::before {
      content: "+";
      margin-right: 8px;
      color: #f37121;
    }
    .scope-cta {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
    }
    .scope-cta .btn { min-width: 176px; }
    .scope-note {
      color: rgba(255,255,255,.64);
      font-size: 13px;
      line-height: 1.7;
      max-width: 440px;
    }

    .final-cta { padding: 80px 0; color: white; background: white; }
    .cta-panel { display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: center; padding: 46px; border-radius: 28px; background: radial-gradient(circle at 10% 20%, rgba(21,159,230,.42), transparent 26%), linear-gradient(135deg, #081521, #0c0c11 72%); box-shadow: var(--shadow); }
    .cta-panel h2 { font-size: clamp(34px, 4vw, 52px); line-height: 1; letter-spacing: -.06em; margin-bottom: 10px; }
    .cta-panel p { max-width: 620px; color: rgba(255,255,255,.75); font-size: 17px; }
    .cta-buttons { display: flex; gap: 14px; flex-wrap: wrap; }

    .site-footer { color: white; background: #111114; padding: 56px 0 28px; }
