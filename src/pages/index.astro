    .stories-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.18fr) minmax(320px, .82fr);
      gap: 24px;
      align-items: stretch;
    }
    .stories-side {
      display: grid;
      gap: 24px;
    }
    .story-card {
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 24px;
      background: white;
      box-shadow: var(--shadow-soft);
    }
    .story-card.featured {
      display: grid;
      grid-template-rows: 280px 1fr;
    }
