    .story-image.maxis { background-image: url("https://novoreperio.com/wp-content/uploads/2023/10/3.webp"); }
    .story-image.wtckl { background-image: url("https://novoreperio.com/wp-content/uploads/2023/10/01.18.2023_13.45.49.webp"); }
    .story-chip {
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      min-height: 40px;
      padding: 0 14px;
      border-radius: 999px;
      color: white;
      background: rgba(7,9,12,.48);
      border: 1px solid rgba(255,255,255,.14);
      backdrop-filter: blur(14px);
      font-size: 14px;
      font-weight: 900;
      letter-spacing: .04em;
      text-transform: uppercase;
    }
    .story-body {
      display: flex;
