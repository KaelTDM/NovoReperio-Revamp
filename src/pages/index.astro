const renderLucideIcon = (iconNode) => {
  const body = iconNode
    .map(([tag, attrs]) => {
      const attrString = Object.entries(attrs)
        .map(([key, value]) => `${key}="${String(value)}"`)
        .join(" ");
      return `<${tag} ${attrString}></${tag}>`;
    })
    .join("");

  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${body}</svg>`;
};
---

<SiteLayout
  title="Novo Reperio | Digital Twins, 360 Tours, Immersive Space Marketing"
  description="Novo Reperio creates digital twins, 360 tours, and launch-ready visual experiences for venues, property teams, museums, and facilities."
>
  <style is:global>
    :root {
      --nr-red: #159fe6;
      --nr-red-dark: #0f83bf;
      --ink: #101114;
      --muted: #6b7280;
      --line: #e8e8ec;
      --soft: #f7f4f1;
      --dark: #101014;
      --white: #ffffff;
      --radius-xl: 28px;
      --radius-lg: 20px;
      --shadow: 0 18px 50px rgba(16, 17, 20, 0.12);
      --shadow-soft: 0 12px 30px rgba(16, 17, 20, 0.08);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background: #fff;
      line-height: 1.5;
    }
    a { color: inherit; text-decoration: none; }
    button, input, textarea { font: inherit; }
    .container { width: min(1180px, calc(100% - 48px)); margin: 0 auto; }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 46px;
      padding: 0 22px;
      border-radius: 10px;
      border: 1px solid transparent;
      font-weight: 800;
      font-size: 14px;
      cursor: pointer;
      transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease, background .2s ease;
    }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 12px 24px rgba(21, 159, 230, .18); }
    .btn-primary { color: white; background: var(--nr-red); border-color: var(--nr-red); }
    .btn-primary:hover { background: var(--nr-red-dark); }
    .btn-secondary { color: white; border-color: rgba(255,255,255,.55); background: rgba(255,255,255,.06); backdrop-filter: blur(14px); }
    .btn-light { color: var(--ink); background: white; border-color: var(--line); }

    .eyebrow {
      display: inline-flex;
      width: max-content;
      align-items: center;
      gap: 8px;
      padding: 7px 11px;
      border-radius: 999px;
      color: #ffffff;
      background: #e4126a;
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .06em;
      text-transform: uppercase;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(12,12,15,.82);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .nav { display: flex; align-items: center; justify-content: space-between; min-height: 72px; color: white; }
    .brand { display: inline-flex; align-items: center; gap: 10px; font-size: 20px; font-weight: 900; letter-spacing: -.03em; }
    .brand-mark {
      width: 192px;
      height: 40px;
      display: block;
      object-fit: contain;
      object-position: center;
    }
    .nav-links, .nav-actions { display: flex; align-items: center; gap: 24px; }
    .nav-links a {
      position: relative;
      color: rgba(255,255,255,.86);
      font-size: 14px;
      font-weight: 700;
      transition: color .22s ease;
    }
    .nav-links a::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: -10px;
      height: 2px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(21,159,230,.25), #159fe6 40%, rgba(21,159,230,.25));
      transform: scaleX(.28);
      transform-origin: center;
      opacity: 0;
      transition: transform .26s ease, opacity .26s ease;
      box-shadow: 0 0 14px rgba(21,159,230,.28);
    }
    .nav-links a:hover,
    .nav-links a:focus-visible {
      color: #ffffff;
    }
    .nav-links a:hover::after,
    .nav-links a:focus-visible::after {
      transform: scaleX(1);
      opacity: 1;
    }
    .nav-actions .utility { color: rgba(255,255,255,.8); font-size: 13px; font-weight: 700; }

    .hero {
      position: relative;
      overflow: hidden;
      color: white;
      background:
        radial-gradient(circle at 75% 16%, rgba(21,159,230,.24), transparent 30%),
        linear-gradient(115deg, rgba(6,6,8,.98) 0%, rgba(12,12,15,.94) 40%, rgba(12,12,15,.86) 100%);
      padding: 86px 0 126px;
    }
    .hero-mesh {
      position: absolute;
      inset: -10% -8%;
      background:
        radial-gradient(circle, rgba(255,255,255,.18) 0 1px, transparent 1.8px) 0 0 / 22px 22px,
        radial-gradient(circle, rgba(21,159,230,.14) 0 1px, transparent 2px) 11px 11px / 22px 22px;
      opacity: .34;
      transform:
        perspective(1100px)
        rotateX(72deg)
        scale(1.55)
        translate3d(0, 8%, 0);
      transform-origin: center center;
      animation: heroMeshFloat 18s ease-in-out infinite alternate;
      filter: blur(.15px);
    }
    .hero-mesh::before,
    .hero-mesh::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 50% 50%, rgba(255,255,255,.24), transparent 46%),
        linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,0));
      opacity: .55;
      mix-blend-mode: screen;
      animation: heroMeshShimmer 11s linear infinite;
    }
    .hero-mesh::after {
      background:
        radial-gradient(circle at 45% 35%, rgba(21,159,230,.18), transparent 38%),
        linear-gradient(90deg, rgba(255,255,255,.02), rgba(255,255,255,0));
      opacity: .52;
      animation-duration: 15s;
      animation-direction: reverse;
    }
    .hero-vignette {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 50% 38%, rgba(21,159,230,.10), transparent 28%),
        radial-gradient(circle at 50% 55%, rgba(0,0,0,0), rgba(0,0,0,.42) 75%);
      pointer-events: none;
      z-index: 0;
    }
    .hero-cursor-glow {
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0;
      z-index: 1;
      transition: opacity .2s ease;
      background:
        radial-gradient(
          240px circle at var(--cursor-x, 50%) var(--cursor-y, 50%),
          rgba(21,159,230,.18) 0%,
          rgba(21,159,230,.10) 28%,
          rgba(21,159,230,0) 70%
        );
      mix-blend-mode: screen;
    }
    .hero.is-glow-active .hero-cursor-glow { opacity: 1; }
    @keyframes heroMeshFloat {
      0% {
        transform:
          perspective(1100px)
          rotateX(72deg)
          rotateZ(-1.5deg)
          scale(1.5)
          translate3d(-2%, 7%, 0);
      }
      50% {
        transform:
          perspective(1100px)
          rotateX(69deg)
          rotateZ(0deg)
          scale(1.56)
          translate3d(1%, 4%, 0);
      }
      100% {
        transform:
          perspective(1100px)
          rotateX(73deg)
          rotateZ(1.2deg)
          scale(1.52)
          translate3d(3%, 8%, 0);
      }
    }
    @keyframes heroMeshShimmer {
      0% { transform: translate3d(-3%, 0, 0) scale(1); opacity: .34; }
      50% { transform: translate3d(2%, -1%, 0) scale(1.03); opacity: .6; }
      100% { transform: translate3d(-3%, 0, 0) scale(1); opacity: .34; }
    }
    .hero-grid { position: relative; z-index: 2; display: grid; grid-template-columns: .82fr 1.18fr; align-items: center; gap: 64px; }
    .hero-copy {
      position: relative;
      z-index: 3;
      isolation: isolate;
    }
    .hero-copy::before {
      content: "";
      position: absolute;
      inset: -22px -34px -26px -26px;
      z-index: -1;
      background:
        radial-gradient(circle at 22% 26%, rgba(8,11,16,.72), transparent 58%),
        linear-gradient(90deg, rgba(8,11,16,.54) 0%, rgba(8,11,16,.26) 48%, rgba(8,11,16,0) 100%);
      filter: blur(12px);
      pointer-events: none;
    }
    .hero-copy h1 {
      max-width: 680px;
      margin: 20px 0 22px;
      color: rgba(255,255,255,.96);
      font-size: clamp(48px, 6vw, 86px);
      line-height: .95;
      letter-spacing: -.07em;
      text-shadow: 0 8px 28px rgba(0,0,0,.22);
    }
    .hero-copy p {
      max-width: 560px;
      color: rgba(255,255,255,.90);
      font-size: 19px;
      line-height: 1.65;
      text-shadow: 0 4px 18px rgba(0,0,0,.18);
    }
    .hero-actions { display: flex; flex-wrap: wrap; gap: 14px; margin: 32px 0 18px; }
    .hero-checks { display: flex; gap: 24px; color: rgba(255,255,255,.90); font-size: 13px; font-weight: 800; }
    .hero-checks span::before { content: "+"; color: var(--nr-red); margin-right: 8px; }
    .logo-row { margin-top: 44px; }
    .logo-row small { display: block; color: rgba(255,255,255,.68); font-size: 11px; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; }
    .hero-note { margin-top: 14px; color: rgba(255,255,255,.76); font-size: 14px; max-width: 560px; }
    .logo-section { padding: 26px 0 8px; }
    .logo-panel { padding: 10px 0 0; }
    .logo-section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 22px;
    }
    .logo-section-head p {
      max-width: 520px;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.8;
    }
    .logo-block + .logo-block { margin-top: 18px; padding-top: 18px; border-top: 1px solid rgba(16,17,20,.08); }
    .logo-block small {
      display: block;
      margin-bottom: 16px;
      color: #7a808c;
      font-size: 11px;
      font-weight: 900;
      letter-spacing: .14em;
      text-transform: uppercase;
    }
    .logo-marquee {
      position: relative;
      overflow: hidden;
      border-radius: 999px;
      mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    }
    .logo-marquee::before,
    .logo-marquee::after {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      width: 56px;
      z-index: 2;
      pointer-events: none;
    }
    .logo-marquee::before { left: 0; background: linear-gradient(90deg, #fff, rgba(255,255,255,0)); }
    .logo-marquee::after { right: 0; background: linear-gradient(270deg, #fff, rgba(255,255,255,0)); }
    .logo-track {
      display: flex;
      width: max-content;
      align-items: center;
      gap: 44px;
      padding: 12px 0;
      animation: logo-marquee 34s linear infinite;
    }
    .logo-track.reverse {
      animation-direction: reverse;
      animation-duration: 40s;
    }
    .logo-card {
      flex: 0 0 auto;
      display: grid;
