      gap: 4px;
    }
    .stack-browser-dots span {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: rgba(16,17,20,.22);
    }
    .stack-board.is-rotating .stack-core-top,
    .stack-board.is-rotating [data-stack-title],
    .stack-board.is-rotating [data-stack-description],
    .stack-board.is-rotating [data-stack-flow],
    .stack-board.is-rotating [data-stack-metrics] {
      opacity: 0;
      transform: translateY(18px);
    }
    .stack-board.is-rotating [data-stack-core-visual],
    .stack-board.is-rotating .stack-support-card small,
    .stack-board.is-rotating .stack-support-card strong,
    .stack-board.is-rotating .stack-support-card .stack-support-visual,
    .stack-board.is-rotating .stack-support-card .stack-orb,
    .stack-board.is-rotating .stack-support-card .stack-browser {
