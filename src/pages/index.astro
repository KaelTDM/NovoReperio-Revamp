    .stack-orb {
      position: absolute;
      right: 22px;
      bottom: 22px;
      width: 92px;
      height: 92px;
      border-radius: 50%;
      background:
        radial-gradient(circle at 34% 34%, rgba(255,255,255,.95), rgba(255,255,255,.14) 28%, rgba(21,159,230,.16) 55%, rgba(21,159,230,.02) 74%),
        radial-gradient(circle at 50% 50%, rgba(21,159,230,.18), transparent 72%);
