---

<SiteLayout
  title="Novo Reperio Services | Matterport, 360 Tours, Drone & Aerial"
  description="Explore Novo Reperio services across Matterport virtual tours, 360 tours, drone and aerial visuals, web development, and supporting visual production."
>
  <style is:global>
    :root {
      --nr-blue: #159fe6;
      --nr-blue-dark: #0f83bf;
      --nr-pink: #e4126a;
      --nr-orange: #f37121;
      --ink: #101114;
      --muted: #6b7280;
      --line: rgba(16, 17, 20, 0.1);
      --white: #ffffff;
      --surface: #fbfcfe;
      --soft: #f7f8fb;
      --dark: #0d1118;
      --shadow: 0 18px 50px rgba(16, 17, 20, 0.12);
      --shadow-soft: 0 12px 30px rgba(16, 17, 20, 0.08);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background: #fff;
      line-height: 1.5;
    }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    button, input, textarea { font: inherit; }

    .container,
    .wide-shell {
      width: 100%;
      max-width: 1680px;
      margin: 0 auto;
      padding-inline: 100px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 48px;
      padding: 0 22px;
      border-radius: 10px;
      border: 1px solid transparent;
      font-size: 14px;
      font-weight: 800;
      transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease, background .2s ease, color .2s ease;
    }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 12px 24px rgba(21,159,230,.18); }
    .btn-primary { color: #fff; background: var(--nr-blue); border-color: var(--nr-blue); }
    .btn-primary:hover { background: var(--nr-blue-dark); }
    .btn-secondary { color: #fff; border-color: rgba(255,255,255,.55); background: rgba(255,255,255,.06); backdrop-filter: blur(14px); }
    .btn-light { color: var(--nr-blue); background: #fff; border-color: rgba(21,159,230,.2); }
    .btn-light:hover { color: #fff; background: var(--nr-blue); border-color: var(--nr-blue); }

    .eyebrow {
      display: inline-flex;
      width: max-content;
      align-items: center;
      gap: 8px;
      padding: 7px 11px;
      border-radius: 999px;
      color: #fff;
      background: var(--nr-pink);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .06em;
      text-transform: uppercase;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(12,12,15,.82);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .nav { display: flex; align-items: center; justify-content: space-between; min-height: 72px; color: #fff; }
    .brand { display: inline-flex; align-items: center; }
    .brand-mark {
      width: 192px;
      height: 40px;
      display: block;
      object-fit: contain;
      object-position: center;
    }
    .nav-links, .nav-actions { display: flex; align-items: center; gap: 24px; }
    .nav-links a {
      position: relative;
      color: rgba(255,255,255,.86);
      font-size: 14px;
      font-weight: 700;
      transition: color .22s ease;
    }
    .nav-links a::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: -10px;
      height: 2px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(21,159,230,.25), #159fe6 40%, rgba(21,159,230,.25));
      transform: scaleX(.28);
      transform-origin: center;
      opacity: 0;
      transition: transform .26s ease, opacity .26s ease;
      box-shadow: 0 0 14px rgba(21,159,230,.28);
    }
    .nav-links a:hover,
    .nav-links a:focus-visible,
    .nav-links a.is-active {
      color: #fff;
    }
    .nav-links a:hover::after,
    .nav-links a:focus-visible::after,
    .nav-links a.is-active::after {
      transform: scaleX(1);
      opacity: 1;
    }

    .services-hero {
      position: relative;
      overflow: hidden;
      color: #fff;
      background:
        radial-gradient(circle at 76% 18%, rgba(21,159,230,.24), transparent 28%),
        linear-gradient(112deg, rgba(6,6,8,.99) 0%, rgba(12,12,15,.95) 40%, rgba(12,12,15,.88) 100%);
      padding: 92px 0 110px;
    }
    .services-hero::before {
      content: "";
      position: absolute;
      inset: auto -10% -35% -10%;
      height: 64%;
      background:
        radial-gradient(circle, rgba(255,255,255,.13) 0 1px, transparent 1.8px) 0 0 / 22px 22px,
        radial-gradient(circle, rgba(21,159,230,.14) 0 1px, transparent 2px) 11px 11px / 22px 22px;
      opacity: .24;
      transform: perspective(1100px) rotateX(74deg) scale(1.68);
      pointer-events: none;
    }
    .hero-layout {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, .82fr) minmax(0, 1.18fr);
      gap: 42px;
      align-items: center;
    }
    .hero-copy h1 {
      max-width: 700px;
      margin: 18px 0 22px;
      font-size: clamp(48px, 6vw, 86px);
      line-height: .94;
      letter-spacing: -.07em;
    }
    .hero-copy p {
      max-width: 580px;
      color: rgba(255,255,255,.86);
      font-size: 19px;
      line-height: 1.65;
    }
    .hero-actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 32px; }
    .hero-proof {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 22px;
      color: rgba(255,255,255,.84);
      font-size: 13px;
      font-weight: 800;
    }
    .hero-proof span {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.08);
    }
    .hero-proof span::before {
      content: "";
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--nr-orange);
      box-shadow: 0 0 0 5px rgba(243,113,33,.13);
    }

    .hero-visual-stage {
      position: relative;
      min-height: 660px;
      isolation: isolate;
    }
    .hero-main-frame {
      position: absolute;
      inset: 22px 18px 22px 18px;
      border-radius: 40px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.1);
      background:
        linear-gradient(180deg, rgba(7,10,15,.16), rgba(7,10,15,.72)),
        url("https://novoreperio.com/wp-content/uploads/2023/10/01.18.2023_13.45.49.webp") center/cover;
      box-shadow: 0 30px 72px rgba(0,0,0,.28);
    }
    .hero-main-frame::before {
      content: "";
      position: absolute;
      inset: auto -16% -34% auto;
      width: 320px;
      height: 320px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(21,159,230,.34), transparent 62%);
      filter: blur(16px);
    }
    .hero-main-frame::after {
      content: "";
      position: absolute;
      inset: 22px;
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,.1);
      pointer-events: none;
    }
    .hero-service-tile {
      position: absolute;
      width: 228px;
      padding: 20px;
      border-radius: 24px;
      background: rgba(255,255,255,.96);
      color: var(--ink);
      border: 1px solid rgba(255,255,255,.18);
      box-shadow: 0 22px 44px rgba(0,0,0,.22);
      backdrop-filter: blur(18px);
    }
    .hero-service-tile small {
      display: block;
      margin-bottom: 10px;
      color: #7a808c;
      font-size: 11px;
      font-weight: 900;
      letter-spacing: .12em;
      text-transform: uppercase;
    }
    .hero-service-tile strong {
      display: block;
      margin-bottom: 8px;
      font-size: 24px;
      line-height: 1.04;
      letter-spacing: -.05em;
    }
    .hero-service-tile p {
      max-width: 150px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.6;
    }
    .hero-service-tile .mini-drone {
      position: absolute;
      right: 14px;
      bottom: 14px;
    }
    .hero-service-tile .mini-drone {
      width: 72px;
      filter: drop-shadow(0 10px 20px rgba(16,17,20,.12));
    }
    .hero-service-tile.matterport {
      top: 42px;
      right: 18px;
      width: 236px;
      background: rgba(9,12,18,.9);
      color: #fff;
      border-color: rgba(255,255,255,.08);
    }
    .hero-service-tile.matterport small { color: rgba(255,255,255,.62); }
    .hero-service-tile.matterport p { color: rgba(255,255,255,.74); }
    .hero-service-tile.drone {
      right: 18px;
      bottom: 42px;
    }
    .hero-frame-copy {
      position: absolute;
      top: 42px;
      left: 42px;
      max-width: 290px;
      padding: 20px 22px;
      border-radius: 20px;
      color: #fff;
      background: rgba(10,12,18,.84);
      backdrop-filter: blur(18px);
      border: 1px solid rgba(255,255,255,.08);
      z-index: 2;
    }
    .hero-frame-copy strong {
      display: block;
      margin-bottom: 6px;
      font-size: 18px;
      letter-spacing: -.03em;
    }
    .hero-frame-copy span {
      display: block;
      color: rgba(255,255,255,.74);
      font-size: 13px;
      line-height: 1.65;
    }
    .hero-stage-actions {
      position: absolute;
      left: 42px;
      bottom: 42px;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }
    .hero-stage-cta {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      min-height: 54px;
      padding: 0 20px;
      border-radius: 18px;
      color: #fff;
      font-size: 13px;
      font-weight: 900;
      letter-spacing: .08em;
      text-transform: uppercase;
      text-decoration: none;
      background: rgba(8,12,18,.82);
      border: 1px solid rgba(255,255,255,.12);
      box-shadow: 0 18px 34px rgba(0,0,0,.28);
      transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease, background .28s ease;
    }
    .hero-stage-cta::after {
      content: "->";
      color: var(--nr-blue);
      font-size: 16px;
      font-weight: 900;
    }
    .hero-stage-cta:hover {
      transform: translateY(-2px);
      border-color: rgba(21,159,230,.36);
      background: rgba(9,14,22,.92);
      box-shadow: 0 22px 42px rgba(8,16,28,.34);
    }
    .hero-visual-rail {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      max-width: 420px;
      padding: 12px;
      border-radius: 20px;
      background: rgba(8,12,18,.68);
      border: 1px solid rgba(255,255,255,.1);
      backdrop-filter: blur(18px);
      box-shadow: 0 18px 34px rgba(0,0,0,.24);
    }
    .hero-visual-rail span {
      display: inline-flex;
      align-items: center;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      color: rgba(255,255,255,.84);
      border: 1px solid rgba(255,255,255,.1);
      background: rgba(255,255,255,.06);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: .11em;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .hero-visual-rail span.is-accent {
      color: #fff;
      border-color: rgba(21,159,230,.36);
      background: rgba(21,159,230,.16);
    }

    .section { padding: 92px 0; }
    .section-title { margin-bottom: 34px; }
    .section-title h2 {
      max-width: 940px;
      font-size: clamp(34px, 4vw, 58px);
      line-height: .98;
      letter-spacing: -.06em;
    }
    .section-title p {
      max-width: 720px;
      margin-top: 18px;
      color: var(--muted);
      font-size: 18px;
      line-height: 1.75;
    }

    .services-overview {
      padding-top: 40px;
    }
    .service-card-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
      margin-top: 28px;
    }
    .service-card-button {
      position: relative;
      display: flex;
      width: 100%;
      min-height: 198px;
      flex-direction: column;
      justify-content: space-between;
      gap: 18px;
      padding: 22px;
      border: 1px solid rgba(16,17,20,.08);
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(247,250,253,.98));
      box-shadow: var(--shadow-soft);
      text-align: left;
      cursor: pointer;
      transition: transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s ease, border-color .3s ease, background .3s ease;
    }
    .service-card-button:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 38px rgba(16,17,20,.12);
    }
    .service-card-button.is-paused-hover {
      border-color: rgba(21,159,230,.54);
      box-shadow:
        0 0 0 1px rgba(21,159,230,.18),
        0 18px 38px rgba(21,159,230,.16),
        0 0 32px rgba(21,159,230,.18);
      transform: translateY(-6px) scale(1.018);
    }
    .service-card-button.is-active {
      border-color: rgba(21,159,230,.34);
      background: linear-gradient(180deg, rgba(238,247,255,.98), rgba(248,251,255,.98));
      box-shadow: 0 24px 48px rgba(21,159,230,.12);
      transform: translateY(-3px);
    }
    .service-card-button[data-tone="dark"] {
      color: #fff;
      border-color: rgba(255,255,255,.1);
      background:
        radial-gradient(circle at 92% 10%, rgba(21,159,230,.18), transparent 24%),
        linear-gradient(180deg, rgba(11,13,19,.98), rgba(15,19,27,.98));
    }
    .service-card-button[data-tone="dark"].is-active {
      border-color: rgba(21,159,230,.44);
      box-shadow: 0 26px 54px rgba(7,12,20,.26);
    }
    .service-card-button[data-tone="dark"].is-paused-hover {
      border-color: rgba(21,159,230,.64);
      box-shadow:
        0 0 0 1px rgba(21,159,230,.22),
        0 22px 44px rgba(7,12,20,.28),
        0 0 38px rgba(21,159,230,.2);
      background:
        radial-gradient(circle at 92% 10%, rgba(21,159,230,.26), transparent 24%),
        linear-gradient(180deg, rgba(11,13,19,.98), rgba(15,19,27,.98));
    }
    .service-card-button.is-active.is-paused-hover {
      border-color: rgba(21,159,230,.62);
      box-shadow:
        0 0 0 1px rgba(21,159,230,.2),
        0 28px 56px rgba(21,159,230,.18),
        0 0 36px rgba(21,159,230,.18);
      transform: translateY(-8px) scale(1.02);
    }
    .service-card-button[data-tone="dark"].is-active.is-paused-hover {
      border-color: rgba(21,159,230,.72);
      box-shadow:
        0 0 0 1px rgba(21,159,230,.24),
        0 28px 58px rgba(7,12,20,.34),
        0 0 42px rgba(21,159,230,.24);
      background:
        radial-gradient(circle at 92% 10%, rgba(21,159,230,.28), transparent 24%),
        linear-gradient(180deg, rgba(11,13,19,.98), rgba(15,19,27,.98));
      transform: translateY(-8px) scale(1.02);
    }
    .service-card-button.is-active::after {
      content: "";
      position: absolute;
      inset: auto 18px 12px;
      height: 3px;
      border-radius: 999px;
