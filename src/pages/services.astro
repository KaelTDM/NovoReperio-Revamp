  <script define:vars={{ mainServices }}>
    const serviceRotator = document.querySelector("[data-service-rotator]");
    const serviceCards = Array.from(document.querySelectorAll("[data-service-card]"));
    const servicePanel = document.querySelector("[data-service-panel]");
    const serviceVisual = document.querySelector("[data-service-visual]");
    const serviceKicker = document.querySelector("[data-service-kicker]");
    const serviceStatLabel = document.querySelector("[data-service-stat-label]");
    const serviceStatValue = document.querySelector("[data-service-stat-value]");
    const serviceTitle = document.querySelector("[data-service-title]");
    const serviceDescription = document.querySelector("[data-service-description]");
    const serviceBullets = document.querySelector("[data-service-bullets]");
    const servicePrimaryCta = document.querySelector("[data-service-primary-cta]");
    const serviceSecondaryCta = document.querySelector("[data-service-secondary-cta]");

    if (
      serviceCards.length &&
      servicePanel &&
      serviceVisual &&
      serviceKicker &&
      serviceStatLabel &&
      serviceStatValue &&
      serviceTitle &&
      serviceDescription &&
      serviceBullets &&
      servicePrimaryCta &&
      serviceSecondaryCta
    ) {
      let activeServiceId = mainServices[0]?.id || "";
      let switchTimer;
      let autoRotateTimer;
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const renderVisual = (service) => {
        if (service.visual === "matterport") {
          return `
            <div class="service-detail-visual matterport" data-service-visual>
              <iframe
                src="${service.iframeSrc}"
                title="${service.iframeTitle}"
                loading="lazy"
                allow="fullscreen; xr-spatial-tracking; vr"
                allowfullscreen
              ></iframe>
            </div>
          `;
        }

        if (service.visual === "tours") {
          return `
            <div class="service-detail-visual tours" data-service-visual>
              <div class="service-detail-note">A polished virtual tour experience that opens quickly across mobile, desktop, and tablet.</div>
            </div>
          `;
        }

        return `
          <div class="service-detail-visual drone" data-service-visual>
            <div class="service-detail-note">Show location, surroundings, scale, and approach with elegant aerial visuals.</div>
            <img class="service-detail-drone-image" src="/images/drone.png" alt="" loading="lazy" />
          </div>
        `;
      };

      let currentVisual = serviceVisual;

      const commitService = (service) => {
        servicePanel.dataset.tone = service.cardTone;

        const nextVisualMarkup = renderVisual(service);
        currentVisual.insertAdjacentHTML("afterend", nextVisualMarkup);
        currentVisual.remove();

        const freshVisual = document.querySelector("[data-service-visual]");
        serviceKicker.textContent = service.label;
        serviceStatLabel.textContent = service.statLabel;
        serviceStatValue.textContent = service.statValue;
        serviceTitle.textContent = service.detailTitle;
        serviceDescription.textContent = service.detailDescription;
        serviceBullets.innerHTML = service.bullets.map((bullet) => `<li>${bullet}</li>`).join("");
        servicePrimaryCta.textContent = service.primaryCtaLabel;
        servicePrimaryCta.href = service.primaryCtaUrl;
        serviceSecondaryCta.textContent = service.secondaryCtaLabel;
        serviceSecondaryCta.href = service.secondaryCtaUrl;

        return freshVisual;
      };

      const activateService = (id, updateHash = true) => {
        if (!id) return;

        const service = mainServices.find((item) => item.id === id);
        if (!service || id === activeServiceId) return;

        serviceCards.forEach((card) => {
          const isActive = card.dataset.serviceId === id;
          card.classList.toggle("is-active", isActive);
          card.setAttribute("aria-pressed", isActive ? "true" : "false");
        });

        servicePanel.classList.add("is-switching");
        window.clearTimeout(switchTimer);

        switchTimer = window.setTimeout(() => {
          currentVisual = commitService(service) || currentVisual;
          activeServiceId = id;
          servicePanel.classList.remove("is-switching");
        }, 260);

        if (updateHash) {
          history.replaceState(null, "", `#${id}`);
        }
      };

      const startAutoRotate = () => {
        if (prefersReducedMotion) return;
        window.clearInterval(autoRotateTimer);
        autoRotateTimer = window.setInterval(() => {
          const currentIndex = mainServices.findIndex((item) => item.id === activeServiceId);
          const nextIndex = (currentIndex + 1) % mainServices.length;
          activateService(mainServices[nextIndex].id, false);
        }, 7000);
      };

      const stopAutoRotate = () => {
        window.clearInterval(autoRotateTimer);
      };

      serviceCards.forEach((card) => {
        card.addEventListener("click", () => {
          activateService(card.dataset.serviceId);
          startAutoRotate();
        });
        card.addEventListener("mouseenter", () => {
          card.classList.add("is-paused-hover");
        });
        card.addEventListener("mouseleave", () => {
          card.classList.remove("is-paused-hover");
        });
        card.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            activateService(card.dataset.serviceId);
            startAutoRotate();
          }
        });
      });

      const activateFromHash = () => {
        const hashId = window.location.hash.replace("#", "");
        if (!hashId) return;

        const card = serviceCards.find((item) => item.dataset.serviceId === hashId);
        if (card) {
          activateService(hashId, false);
          card.scrollIntoView({ block: "nearest", behavior: "smooth" });
        }
      };

      window.addEventListener("hashchange", activateFromHash);
      activateFromHash();

      if (serviceRotator) {
        serviceRotator.addEventListener("mouseenter", stopAutoRotate);
        serviceRotator.addEventListener("mouseleave", startAutoRotate);
        serviceRotator.addEventListener("focusin", stopAutoRotate);
        serviceRotator.addEventListener("focusout", startAutoRotate);
      }

      servicePanel.addEventListener("mouseenter", () => {
        servicePanel.classList.add("is-paused-hover");
      });

      servicePanel.addEventListener("mouseleave", () => {
        servicePanel.classList.remove("is-paused-hover");
      });

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          stopAutoRotate();
        } else {
          startAutoRotate();
        }
      });

      startAutoRotate();
    }
  </script>

