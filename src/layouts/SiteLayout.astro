---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Novo Reperio",
  description = "Fresh project scaffold for the Novo Reperio website redesign.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d0f14" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
